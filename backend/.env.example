# Multi-Platform Publisher - Backend Configuration
# Copy this file to backend/.env and fill in your values

# Server port
PORT=3000

# API key for external access (optional, for MCP integration)
PUBLISHER_API_KEY=

# Database (SQLite for demo, Postgres for production)
DATABASE_URL=file:./data.db

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# Platform credentials (fill only if using real APIs)
# XHS_COOKIE=  # Xiaohongshu
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# LINKEDIN_ACCESS_TOKEN=

# Log level
LOG_LEVEL=info
